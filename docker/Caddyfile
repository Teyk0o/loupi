# Loupi — Caddy reverse proxy configuration
# Routes API requests to the Go backend, everything else to Next.js.
#
# In production, set LOUPI_DOMAIN to enable automatic HTTPS.
# Without it, Caddy listens on :80 (HTTP only).

{$LOUPI_DOMAIN::80} {
	# API routes → Go backend
	handle /v1/* {
		reverse_proxy localhost:8080
	}

	# Everything else → Next.js frontend
	handle {
		reverse_proxy localhost:3000
	}

	# Healthcheck endpoint
	handle /health {
		respond "OK" 200
	}

	# Logging
	log {
		output stderr
		format console
	}
}
