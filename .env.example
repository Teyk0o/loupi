# =============================================================================
# Loupi — Environment variables
# Copy this file to .env and adjust the values before deploying.
# =============================================================================

# Database
LOUPI_DB_NAME=loupi
LOUPI_DB_USER=loupi
LOUPI_DB_PASSWORD=change-me-to-a-strong-password

# Redis (generate with: openssl rand -base64 32)
LOUPI_REDIS_PASSWORD=change-me-to-a-strong-redis-password

# Security (REQUIRED — generate with: openssl rand -hex 32)
LOUPI_JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
LOUPI_ENCRYPTION_KEY=change-me-generate-with-openssl-rand-hex-32

# Domain (set to your domain for automatic HTTPS, e.g. dashboard.loupi.example.com)
# Leave empty or :80 for HTTP-only (e.g. behind another reverse proxy)
LOUPI_DOMAIN=:80

# API domain (optional, e.g. api.loupi.example.com)
# Enables a dedicated subdomain for API access with its own TLS certificate.
# If not set, the API is only reachable via LOUPI_DOMAIN/v1/*.
LOUPI_API_DOMAIN=

# CORS allowed origins (comma-separated, REQUIRED — no wildcard allowed)
# Example: https://dashboard.loupi.example.com
LOUPI_ALLOWED_ORIGINS=
